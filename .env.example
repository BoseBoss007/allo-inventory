# Neon Postgres (get from neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Upstash Redis (get from upstash.com)
UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH_REDIS_URL.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_TOKEN"

# Reservation window in minutes
RESERVATION_TTL_MINUTES=10

# Cron secret (generate a random string)
CRON_SECRET="your-secret-cron-key"
